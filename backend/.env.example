# Base de datos (SQLite para desarrollo)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="cambia-esta-clave-secreta-por-una-de-minimo-64-caracteres-aleatorios-xxxx"
JWT_EXPIRATION="8h"

# 2FA
TOTP_ISSUER="SistemaVouchers"
TOTP_WINDOW=1

# Almacenamiento
STORAGE_PATH="./storage/vouchers"
MAX_FILE_SIZE=10485760

# Servidor
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ============================================================
# PRODUCCION EN RAILWAY (configurar como variables del servicio)
# ------------------------------------------------------------
# Crear un Volume y montarlo en /data. Luego:
#   DATABASE_URL="file:/data/dev.db"     # BD SQLite persistente en el volumen
#   STORAGE_PATH="/data/vouchers"        # imagenes persistentes en el volumen
#   JWT_SECRET="<64+ caracteres aleatorios>"
#   NODE_ENV="production"
#   TOTP_ISSUER="SistemaVouchers"
# PORT lo inyecta Railway automaticamente (no lo fijes).
# CORS_ORIGIN no es necesario: frontend y API van en el mismo origen.
# ============================================================

# ============================================================
# PRODUCCION EN aaPanel (servidor Linux) - crear backend/.env con:
# ------------------------------------------------------------
#   NODE_ENV=production
#   PORT=3000
#   JWT_SECRET="<64+ caracteres aleatorios>"   # generar: openssl rand -hex 48
#   JWT_EXPIRATION="8h"
#   TOTP_ISSUER="SistemaVouchers"
#   TOTP_WINDOW=1
#   MAX_FILE_SIZE=10485760
#   # Rutas ABSOLUTAS persistentes (fuera de la carpeta del repo si se redepliega):
#   DATABASE_URL="file:/www/wwwroot/sistema-vouchers/data/prod.db"
#   STORAGE_PATH="/www/wwwroot/sistema-vouchers/data/vouchers"
#   # CORS_ORIGIN no se usa: el backend sirve el frontend (mismo origen).
# El reverse proxy de Nginx (aaPanel) apunta a http://127.0.0.1:3000.
# ============================================================
